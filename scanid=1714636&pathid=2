@model CSRF.Models.ChangeEmailViewModel

@using (Html.BeginForm("ChangeEmail", "Home", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
{
    @Html.ValidationSummary("", new { @class = "text-danger" })
    <div class="form-group">
        @Html.LabelFor(m => m.Email, new { @class = "col-md-2 control-label" })
        <div class="col-md-10">
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Password, new { @class = "col-md-2 control-label" })
        <div class="col-md-10">
            @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
        </div>
    </div>

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" class="btn btn-default" value="Update Email" />
        </div>
    </div>
}


Controller:

[HttpPost]
public ActionResult ChangeEmail(string password, string Email)
{
    var dbContext = new IdentityDbContext("DefaultConnection");
    var userStore = new UserStore<IdentityUser>(dbContext);
    var userManager = new UserManager<IdentityUser>(userStore);
    var currentUser = userManager.FindById(User.Identity.GetUserId());

    if(ModelState.IsValid)
    {
        if(userManager.CheckPassword(currentUser, password))
        {
            currentUser.Email = Email;
            userManager.Update(currentUser);
        }
    }
   
    return RedirectToAction("Index");
}


Validating the Anti CSRF Token Before the ChangeEmail() Method Runs in the Controller


View:

@model CSRF.Models.ChangeEmailViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("ChangeEmail", "Home", FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
{
    @Html.AntiForgeryToken() @* Passing the Anti-CSRF token to the controller *@

    @Html.ValidationSummary("", new { @class = "text-danger" })
    <div class="form-group">
        @Html.LabelFor(m => m.Email, new { @class = "col-md-2 control-label" })
        <div class="col-md-10">
            @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
        </div>
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Password, new { @class = "col-md-2 control-label" })
        <div class="col-md-10">
            @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
        </div>
    </div>

    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" class="btn btn-default" value="Update Email" />
        </div>
    </div>
}



Controller:

[ValidateAntiForgeryToken] //Validating the Anti-CSRF token before ChangeEmail() runs
[HttpPost]
public ActionResult ChangeEmail(string password, string Email)
{
    var dbContext = new IdentityDbContext("DefaultConnection");
    var userStore = new UserStore<IdentityUser>(dbContext);
    var userManager = new UserManager<IdentityUser>(userStore);
    var currentUser = userManager.FindById(User.Identity.GetUserId());

    if(ModelState.IsValid)
    {
        if(userManager.CheckPassword(currentUser, password))
        {
            currentUser.Email = Email;
            userManager.Update(currentUser);
        }
    }

    return RedirectToAction("Index");
}


